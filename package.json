{
  "name": "acme-widget-basket",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "demo": "ts-node src/index.ts",
    "test": "vitest run --reporter=dot",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint . --ext .ts --fix",
    "ci": "npm run lint && npm run format -- --check && npm test && npm run coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Acme Widget Co — Basket Pricing System (Proof of Concept)",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
  "src/**/*.ts": [
    "eslint --fix",
    "prettier --write"
  ]
},
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "dependencies": {
    "tslib": "^2.6.0"
  }

}
